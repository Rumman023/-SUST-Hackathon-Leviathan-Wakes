# QueueStorm Investigator — environment variables (template, no real secrets)
# Copy this file to `.env` for local development. NEVER commit `.env` itself.
# In production (Render, Fly, Railway, EC2, etc.) set these in the platform's
# environment settings — not in the repo.

# ---------------------------------------------------------------------------
# Core service
# ---------------------------------------------------------------------------

# Port the service binds to (defaults to 8000). The app always binds 0.0.0.0.
# Render / Fly / Railway inject $PORT automatically; this is the local default.
PORT=8000

# Logging level (DEBUG | INFO | WARNING | ERROR). Defaults to INFO.
LOG_LEVEL=INFO

# Wall-clock cap on a single /analyze-ticket request, in seconds. Stays well
# inside the harness's 30 s limit even when the optional LLM is enabled.
REQUEST_TIMEOUT_S=25

# Maximum accepted request body size, in bytes. 32 KB is generous for a
# complaint + a short transaction snippet.
REQUEST_MAX_BYTES=32768


# ---------------------------------------------------------------------------
# OPTIONAL: Hugging Face Qwen auditor + polish
# ---------------------------------------------------------------------------
# Provide a Hugging Face token (https://huggingface.co/settings/tokens) to
# enable a SECOND-OPINION AUDIT and/or tone polish through an open instruct
# model (default: Qwen/Qwen2.5-7B-Instruct). Any of these can be enabled
# independently. All decisions still come from the deterministic rule engine;
# Qwen is strictly advisory and never overrides the rule-based verdict.
#
# Leave HF_TOKEN blank to disable both paths; the service is fully functional
# with no keys set.

# Hugging Face API token. KEEP SECRET. Paste directly in your platform's env,
# never commit. https://huggingface.co/settings/tokens
HF_TOKEN=

# Instruct model served by Hugging Face Inference API. Qwen 2.5 7B is small
# enough to be free-tier friendly on HF and strong enough for short JSON.
HF_MODEL=Qwen/Qwen2.5-7B-Instruct

# Which provider the polish hook (llm.py) routes through:
#   "openai"  -> OpenAI chat completions (requires OPENAI_API_KEY below)
#   "qwen"    -> routes the same polish call through app/llm_qwen.py
USE_LLM_PROVIDER=openai

# 1 -> ask the optional LLM to audit the rule verdict (adds a reason_code and
#      nudges confidence). 0 -> skip audit entirely. Defaults to 1 if unset.
LLM_AUDIT=1

# 1 -> enable customer_reply tone polish. 0 -> keep the rule-engine reply.
#      Polish is gated on (USE_LLM_PROVIDER + matching API key being present).
USE_LLM=0

# Seconds before the optional LLM call gives up and falls back silently.
LLM_TIMEOUT=6


# ---------------------------------------------------------------------------
# OPTIONAL: OpenAI polish (only used when USE_LLM_PROVIDER=openai AND USE_LLM=1)
# ---------------------------------------------------------------------------
# KEEP SECRET. Paste directly in your platform's env, never commit.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
